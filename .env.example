# Database (para busca semântica na KB: PostgreSQL com extensão pgvector — ver docker-compose `pgvector/pgvector:pg16`)
DATABASE_URL=postgresql://openconduit:openconduit@localhost:5432/openconduit

# Auth
JWT_SECRET=change-me-to-a-random-64-character-string-in-production

# Server
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=https://openconduit.yourdomain.com
CORS_ORIGIN=http://localhost:5173
# URL pública da aplicação web onde o cliente abre o inquérito CSAT (mesmo host que o painel em muitos deploys). Por omissão: CORS_ORIGIN em dev, PUBLIC_URL se não definido. Usada também nos links de recuperação de senha (email).
# WEB_APP_PUBLIC_URL=https://app.openconduit.yourdomain.com

# Docker Compose (sem espaço antes do nome da variável)
# Caddy no host: por omissão 8080 (HTTP) e 8443 (HTTPS) no máquina — evita "port 80 already allocated"
# quando o painel/proxy já usa 80. Acesso local: http://localhost:8080
# Para usar 80/443 no host: descomenta e ajusta:
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
#
# Primeiro deploy: RUN_DB_SEED=true e SEED_SUPER_ADMIN=1 para criar utilizador super; depois repor false/0.
# RUN_DB_SEED=false
# SEED_SUPER_ADMIN=0
# SUPER_ADMIN_EMAIL=super@openconduit.dev
# SUPER_ADMIN_PASSWORD=change-me

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Nvoip — softphone SIP embutido no CRM (JsSIP / WebRTC). Credenciais SIP são por utilizador na BD.
# IMPORTANTE: use ramal secundário Nvoip (Configurações → Ramais), NÃO o NumberSIP trunk (ex.: 143087001).
# O trunk usa MicroSIP/UDP (5060); o browser usa WebRTC/WSS (6443) só com ramal secundário.
# Com MicroSIP/PABX externo, desactive a flag nvoip_embedded_sip — ligações via click-to-call.
# Domínio SIP para registo (padrão Nvoip para ramais secundários / webphone):
# NVOIP_SIP_DOMAIN=app.nvoip.com.br
# URL WSS completa (opcional; se omitida, usa wss://NVOIP_SIP_DOMAIN:NVOIP_SIP_WSS_PORT):
# NVOIP_SIP_WSS_URL=wss://app.nvoip.com.br:6443
# NVOIP_SIP_WSS_PORT=6443
# Legado (equivale a NVOIP_SIP_DOMAIN):
# NVOIP_SIP_SERVER=app.nvoip.com.br

# Armazenamento de media (anexos WhatsApp, uploads da inbox). Por omissão: disco local.
# MEDIA_UPLOAD_DIR=./uploads/message-media
# MEDIA_STORAGE_DRIVER=local
# MinIO / S3-compatível (quando MEDIA_STORAGE_DRIVER=minio ou activado no Super Admin)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=openconduit-media
# MINIO_REGION=us-east-1
# MINIO_USE_SSL=false
# URL pública opcional do bucket (senão a API faz proxy em /api/v1/messages/media/:name)
# MINIO_PUBLIC_BASE_URL=

# WhatsApp Provider (configure via Settings UI after setup)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=

# Prompt Hub — pré-visualização com LLM real (opcional). Se definido, administradores podem omitir a chave no painel.
# OPENAI_PROMPT_PREVIEW_KEY=
# OPENAI_API_KEY=
# Base URL da API OpenAI (embeddings + chat). Por omissão: https://api.openai.com/v1
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# Modelo de embeddings para indexar a base de conhecimento (semântica + playground). Por omissão: text-embedding-3-small
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Transcrição de notas de voz (WhatsApp / inbox) quando activada em Configurações da organização. Por omissão: whisper-1
# OPENAI_WHISPER_MODEL=whisper-1
# GEMINI_PROMPT_PREVIEW_KEY=

# Logs de diagnóstico da pesquisa na base de conhecimento do agente nativo (mensagem `agent_kb_debug`, nível warn).
# Com `docker compose` deste repositório, defina no .env da raiz: o serviço `api` em docker-compose.yml repassa
# AGENT_KB_DEBUG, OPENAI_*, GEMINI_* e CORS_ORIGIN para o contentor. Painéis sem esse compose: configure o mesmo no painel.
# AGENT_KB_DEBUG=true

# Servidor SIP Nvoip (WebSocket seguro para JsSIP no browser)
NVOIP_SIP_DOMAIN=app.nvoip.com.br
NVOIP_SIP_WSS_PORT=6443
# NVOIP_SIP_WSS_URL=wss://app.nvoip.com.br:6443

# Environment
# Build Docker do frontend (`web`): bust de cache para logo, favicon e fundo do login. Defina um valor único por deploy
# (ex. timestamp ou hash do commit). O docker-compose repassa ao `docker compose build web`.
# VITE_PUBLIC_ASSETS_VERSION=20260512120000
# Modelo OpenAI para assistência no painel (sugestão de resposta, IA & Insights). Por omissão: gpt-4o-mini
# OPENAI_ASSIST_MODEL=gpt-4o-mini
NODE_ENV=development
