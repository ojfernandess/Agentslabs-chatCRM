# Database
DATABASE_URL=postgresql://openconduit:openconduit@localhost:5432/openconduit

# Auth
JWT_SECRET=change-me-to-a-random-64-character-string-in-production

# Server
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=https://openconduit.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Docker Compose (sem espaço antes do nome da variável)
# Caddy no host: por omissão 8080 (HTTP) e 8443 (HTTPS) no máquina — evita "port 80 already allocated"
# quando o painel/proxy já usa 80. Acesso local: http://localhost:8080
# Para usar 80/443 no host: descomenta e ajusta:
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
#
# Primeiro deploy: RUN_DB_SEED=true e SEED_SUPER_ADMIN=1 para criar utilizador super; depois repor false/0.
# RUN_DB_SEED=false
# SEED_SUPER_ADMIN=0
# SUPER_ADMIN_EMAIL=super@openconduit.dev
# SUPER_ADMIN_PASSWORD=change-me

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# WhatsApp Provider (configure via Settings UI after setup)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=

# Environment
NODE_ENV=development
