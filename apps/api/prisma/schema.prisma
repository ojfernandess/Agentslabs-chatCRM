generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
}

enum ConversationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  TEMPLATE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum BroadcastCampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
}

enum BroadcastChannel {
  WHATSAPP
  EMAIL
  SMS
  TELEGRAM
  INSTAGRAM
  MESSENGER
  PUSH
  WEBHOOK
  VOICE
}

enum BroadcastScheduleType {
  IMMEDIATE
  SCHEDULED
  RECURRING
  EVENT
}

enum BroadcastApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TimelineSubjectType {
  CONTACT
  ACCOUNT
  DEAL
}

enum TeamMemberRole {
  TEAM_ADMIN
  SUPERVISOR
  MEMBER
}

enum TeamChannelKind {
  GENERAL
  ANNOUNCEMENTS
  OPS
}

enum TeamWorkspaceItemType {
  NOTE
  WIKI
  SNIPPET
  FILE_LINK
  YOUTUBE
}

enum TeamChannelMessageType {
  TEXT
  IMAGE
  DOCUMENT
  FILE
}

/// Como o valor à finalização (closure) entra nas somas e como negócios herdam o estado por etapa.
enum LeadValueRollup {
  /// Conta em «Em negociação» / pipeline; negócio fica OPEN.
  PIPELINE
  /// Conta em «Soma dos valores» (vendido); negócio WON.
  WON
  /// Negócio LOST; valor não entra nas somas principais.
  LOST
  /// Suporte etc.: valor e negócio não entram nas somas comerciais.
  NONE
}

enum BotType {
  WEBHOOK
  DIALOGFLOW
  CUSTOM
}

/// Níveis de log de execução de automação (estilo n8n / pipelines).
enum AutomationLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  /// Plano comercial (free | growth | enterprise) — quotas e faturação são informativas até integração de pagamentos.
  planTier            String  @default("free") @map("plan_tier") @db.VarChar(32)
  billingEmail        String? @map("billing_email") @db.VarChar(255)
  /// Limite mensal opcional de mensagens enviadas+recebidas (null = ilimitado na app).
  monthlyMessageQuota Int?    @map("monthly_message_quota")

  users              User[]
  userInvitations    UserInvitation[]
  contacts           Contact[]
  conversations      Conversation[]
  closureRecords     ConversationClosureRecord[]
  tags               Tag[]
  pipelines          Pipeline[]
  accounts           Account[]
  products           Product[]
  deals              Deal[]
  timelineEvents     TimelineEvent[]
  leadTypes          LeadType[]
  reminders          Reminder[]
  messageTemplates   MessageTemplate[]
  autoTagRules       AutoTagRule[]
  settings           Settings?
  auditLogs          AuditLog[]
  featureFlags       OrganizationFeatureFlag[]
  teams              Team[]
  teamChannels       TeamChannel[]
  teamWorkspaceItems TeamWorkspaceItem[]
  bots               Bot[]
  broadcastCampaigns BroadcastCampaign[]
  inboxes            Inbox[]
  inboxEmailFolders  InboxEmailFolder[]
  slaPolicies        SlaPolicy[]
  cannedResponses    CannedResponse[]

  automationKnowledgeArticles    AutomationKnowledgeArticle[]
  automationKnowledgeSources     AutomationKnowledgeSource[]
  automationKnowledgeChunks      AutomationKnowledgeChunk[]
  kbSearchCaches                 KbSearchCache[]
  kbSearchLogs                   KbSearchLog[]
  automationPromptModules        AutomationPromptModule[]
  automationAgentProfiles        AutomationAgentProfile[]
  automationCustomTools          AutomationCustomTool[]
  automationInteractions         AutomationInteraction[]
  automationConversationContexts AutomationConversationContext[]
  automationToolExecutions       AutomationToolExecution[]
  automationExecutions           AutomationExecution[]
  automationExecutionLogSettings AutomationExecutionLogSettings?
  chatbotFlows                   ChatbotFlow[]
  crmFlows                       CrmFlow[]
  leadFinderSegments             LeadFinderSegment[]
  leadFinderSchedules            LeadFinderSchedule[]
  wavoipDevices                  WavoipDevice[]
  wavoipCallLogs                 WavoipCallLog[]
  wavoipIntegrationLogs          WavoipIntegrationLog[]
  threeCxRoutePoints             ThreeCxRoutePoint[]
  threeCxCallLogs                ThreeCxCallLog[]
  threeCxIntegrationLogs         ThreeCxIntegrationLog[]
  nvoipAccount                   NvoipAccount?
  nvoipAgentExtensions           NvoipAgentExtension[]
  nvoipCallLogs                  NvoipCallLog[]
  nvoipIntegrationLogs           NvoipIntegrationLog[]
  nvoipTorpedoDispatches         NvoipTorpedoDispatch[]
  nvoipScheduledTorpedos         NvoipScheduledTorpedo[]
  nvoipSipUsers                  NvoipSipUser[]
  nvoipOtpChallenges             NvoipOtpChallenge[]
  nvoipTrunks                    NvoipTrunk[]

  @@map("organizations")
}

/// Canais de caixa de entrada no estilo [Chatwoot](https://www.chatwoot.com/docs/user-guide/add-inbox-settings).
/// Nem todos têm integração real na app; o valor persiste para organização e evolução futura.
enum InboxChannelType {
  WEBSITE
  FACEBOOK
  WHATSAPP
  SMS
  EMAIL
  API
  TELEGRAM
  LINE
  INSTAGRAM
  VOICE
}

model Inbox {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  description   String?          @db.Text
  channelType   InboxChannelType @default(WHATSAPP) @map("channel_type")
  /// Token secreto (URL) para webhooks e widget. Só mostrar a administradores.
  ingestToken   String?          @unique @map("ingest_token") @db.VarChar(64)
  channelConfig Json?            @map("channel_config")
  isDefault     Boolean          @default(false) @map("is_default")
  /// Bot de triagem (primeira linha) só para esta caixa; se vazio, usa `Settings.agentBotId` da organização.
  agentBotId    String?          @map("agent_bot_id") @db.Uuid
  agentBot      Bot?             @relation("InboxAgentBot", fields: [agentBotId], references: [id], onDelete: SetNull)
  /// Atribuição automática de novas conversas OPEN aos membros da caixa.
  autoAssignEnabled Boolean      @default(false) @map("auto_assign_enabled")
  /// Máximo de conversas ativas (OPEN/PENDING) por agente; null = sem limite numérico.
  autoAssignLimit   Int?         @map("auto_assign_limit")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members            InboxMember[]
  conversations      Conversation[]
  emailFolders       InboxEmailFolder[]
  broadcastCampaigns BroadcastCampaign[]
  wavoipDevices      WavoipDevice[]
  threeCxRoutePoints ThreeCxRoutePoint[]
  nvoipAccounts      NvoipAccount[]

  @@index([organizationId])
  @@index([agentBotId])
  @@map("inboxes")
}

model InboxMember {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  inboxId String @map("inbox_id") @db.Uuid
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inboxId, userId])
  @@index([userId])
  @@map("inbox_members")
}

model Team {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String
  description          String?  @db.Text
  avatarUrl            String?  @map("avatar_url") @db.VarChar(2048)
  businessHours        Json?    @map("business_hours")
  notificationSettings Json?    @map("notification_settings")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members         TeamMember[]
  conversations   Conversation[]
  closureRecords  ConversationClosureRecord[]
  channels        TeamChannel[]
  workspaceItems TeamWorkspaceItem[]

  @@index([organizationId])
  @@map("teams")
}

model TeamChannel {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  description    String?         @db.Text
  kind           TeamChannelKind @default(GENERAL)
  sortOrder      Int             @default(0) @map("sort_order")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teamId String @map("team_id") @db.Uuid
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  messages TeamChannelMessage[]

  @@unique([teamId, name])
  @@index([organizationId])
  @@map("team_channels")
}

model TeamChannelMessage {
  id        String                 @id @default(uuid()) @db.Uuid
  body      String                 @db.Text
  messageType TeamChannelMessageType @default(TEXT) @map("message_type")
  attachmentUrl      String? @map("attachment_url") @db.VarChar(2048)
  attachmentName     String? @map("attachment_name") @db.VarChar(512)
  attachmentMimeType String? @map("attachment_mime_type") @db.VarChar(128)
  createdAt DateTime               @default(now()) @map("created_at")

  channelId String      @map("channel_id") @db.Uuid
  channel   TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  authorUserId String @map("author_user_id") @db.Uuid
  authorUser   User   @relation("TeamChannelMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  reactions TeamChannelMessageReaction[]

  @@index([channelId, createdAt])
  @@map("team_channel_messages")
}

model TeamChannelMessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  emoji     String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  messageId String             @map("message_id") @db.Uuid
  message   TeamChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation("TeamChannelMessageReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("team_channel_message_reactions")
}

model TeamWorkspaceItem {
  id        String                @id @default(uuid()) @db.Uuid
  itemType  TeamWorkspaceItemType @map("item_type")
  title     String
  content   String?               @db.Text
  fileUrl   String?               @map("file_url") @db.VarChar(2048)
  pinned    Boolean               @default(false)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teamId String @map("team_id") @db.Uuid
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String @map("created_by_id") @db.Uuid
  createdBy   User   @relation("TeamWorkspaceItemAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([teamId, itemType])
  @@index([organizationId])
  @@map("team_workspace_items")
}

model TeamMember {
  id        String         @id @default(uuid()) @db.Uuid
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")

  teamId String @map("team_id") @db.Uuid
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Bot {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  avatarUrl   String?  @map("avatar_url") @db.VarChar(2048)
  type        BotType  @default(WEBHOOK)
  webhookUrl  String?  @map("webhook_url") @db.VarChar(2048)
  config      Json?
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inboxTokenPrefix String? @map("inbox_token_prefix") @db.VarChar(16)
  inboxTokenHash   String? @map("inbox_token_hash") @db.Text
  /// Segredo opcional: assinatura HMAC-SHA256 (cabeçalho X-OpenConduit-Signature) nos POST enviados ao webhookUrl.
  webhookSecret    String? @map("webhook_secret") @db.VarChar(512)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  interactions    BotInteraction[]
  settingsAsAgent Settings?        @relation("SettingsAgentBot")
  inboxesAsAgent  Inbox[]          @relation("InboxAgentBot")

  automationProfile              AutomationAgentProfile?
  automationCustomTools          AutomationCustomTool[]
  automationInteractions         AutomationInteraction[]
  automationConversationContexts AutomationConversationContext[]
  automationKnowledgeArticleBots AutomationKnowledgeArticleBot[]
  automationExecutions           AutomationExecution[]
  linkedChatbotFlow              ChatbotFlow?

  @@unique([inboxTokenPrefix])
  @@index([organizationId])
  @@map("bots")
}

model BotInteraction {
  id        String   @id @default(uuid()) @db.Uuid
  direction String   @db.VarChar(32)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  botId String @map("bot_id") @db.Uuid
  bot   Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  conversationId String?       @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([botId, createdAt])
  @@index([conversationId])
  @@map("bot_interactions")
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String
  displayName              String?   @map("display_name") @db.VarChar(200)
  /// URL da foto de perfil do utilizador (upload em Configurações do perfil).
  avatarUrl                String?   @map("avatar_url") @db.VarChar(2048)
  email                    String    @unique
  passwordHash             String    @map("password_hash")
  messageSignature         String?   @map("message_signature") @db.Text
  /// Na UI da conversa, mostrar o nome do atendente em cada mensagem enviada (equipa).
  showAgentNameInChat      Boolean   @default(false) @map("show_agent_name_in_chat")
  /// Token de API pessoal (estilo Chatwoot) para integrações por utilizador.
  apiAccessTokenPrefix     String?   @map("api_access_token_prefix") @db.VarChar(16)
  apiAccessTokenHash       String?   @map("api_access_token_hash") @db.Text
  apiAccessTokenLastUsedAt DateTime? @map("api_access_token_last_used_at")
  role                     UserRole  @default(AGENT)
  createdAt                DateTime  @default(now()) @map("created_at")

  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assignedContacts             Contact[]                     @relation("AssignedContacts")
  createdContacts              Contact[]                     @relation("ContactCreator")
  assignedConversations        Conversation[]                @relation("AssignedConversations")
  reminders                    Reminder[]
  auditLogs                    AuditLog[]
  platformAppsCreated          PlatformApplication[]
  ownedAccounts                Account[]                     @relation("AccountOwner")
  ownedDeals                   Deal[]                        @relation("DealOwner")
  timelineEvents               TimelineEvent[]
  teamMemberships              TeamMember[]
  inboxMemberships             InboxMember[]
  messagesAsActor              Message[]                     @relation("MessageActor")
  broadcastCampaignsCreated    BroadcastCampaign[]           @relation("BroadcastCampaignCreator")
  broadcastCampaignsApproved   BroadcastCampaign[]           @relation("BroadcastCampaignApprover")
  automationKnowledgeRevisions AutomationKnowledgeRevision[]
  conversationReadStates       ConversationUserReadState[]
  conversationEmailStates      ConversationUserEmailState[]
  inboxEmailFolders            InboxEmailFolder[]
  closureRecordsResolved     ConversationClosureRecord[]   @relation("ClosureRecordResolvedBy")
  closureRecordsReopened     ConversationClosureRecord[]   @relation("ClosureRecordReopenedBy")
  closureRecordsAssigned     ConversationClosureRecord[]   @relation("ClosureRecordAssignee")
  passwordResetTokens          PasswordResetToken[]
  invitationsSent              UserInvitation[]              @relation("UserInvitationsSent")
  teamChannelMessages          TeamChannelMessage[]          @relation("TeamChannelMessageAuthor")
  teamChannelMessageReactions  TeamChannelMessageReaction[]  @relation("TeamChannelMessageReactionUser")
  teamWorkspaceItemsAuthored   TeamWorkspaceItem[]           @relation("TeamWorkspaceItemAuthor")
  assignedWavoipDevices        WavoipDevice[]                @relation("WavoipDeviceAssignee")
  wavoipCallsInitiated         WavoipCallLog[]               @relation("WavoipCallInitiator")
  assignedThreeCxRoutePoints   ThreeCxRoutePoint[]           @relation("ThreeCxRoutePointAssignee")
  threeCxCallsInitiated        ThreeCxCallLog[]              @relation("ThreeCxCallInitiator")
  nvoipAgentExtensions         NvoipAgentExtension[]
  nvoipCallsInitiated          NvoipCallLog[]                @relation("NvoipCallInitiator")
  nvoipOtpChallenges           NvoipOtpChallenge[]
  sipCredentials               UserSipCredentials?

  @@index([organizationId])
  @@map("users")
}

/// Credenciais SIP por utilizador (softphone JsSIP embutido no CRM — Nvoip).
model UserSipCredentials {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sipUser        String   @map("sip_user") @db.VarChar(64)
  sipPasswordEnc String   @map("sip_password_enc") @db.Text
  displayName    String?  @map("display_name") @db.VarChar(200)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("user_sip_credentials")
}

/// Token de recuperação de senha (hash SHA-256 do segredo enviado por email).
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Convite por email para novo utilizador da organização (registo via link).
model UserInvitation {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @db.VarChar(255)
  role           UserRole     @default(AGENT)
  tokenHash      String       @unique @map("token_hash") @db.VarChar(64)
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  revokedAt      DateTime?    @map("revoked_at")
  invitedById    String       @map("invited_by_id") @db.Uuid
  invitedBy      User         @relation("UserInvitationsSent", fields: [invitedById], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("user_invitations")
}

/// Última vez que o utilizador abriu a conversa no painel — para ocultar badge de transferência de equipa.
model ConversationUserReadState {
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([userId])
  @@map("conversation_user_read_states")
}

/// Estado de e-mail por utilizador (favorito e pasta personalizada).
model ConversationUserEmailState {
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  isStarred      Boolean  @default(false) @map("is_starred")
  emailFolderId  String?  @map("email_folder_id") @db.Uuid
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  emailFolder  InboxEmailFolder? @relation(fields: [emailFolderId], references: [id], onDelete: SetNull)

  @@id([userId, conversationId])
  @@index([userId, emailFolderId])
  @@index([userId, isStarred])
  @@map("conversation_user_email_states")
}

/// Pasta personalizada de e-mail (por utilizador e caixa).
model InboxEmailFolder {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inboxId String @map("inbox_id") @db.Uuid
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  placements ConversationUserEmailState[]

  @@unique([inboxId, userId, name])
  @@index([inboxId, userId])
  @@map("inbox_email_folders")
}

model Contact {
  id                String    @id @default(uuid()) @db.Uuid
  phone             String
  name              String
  email             String?
  notes             String?   @db.Text
  /// URL da foto de perfil WhatsApp (Evolution API / webhooks CONTACTS_*).
  profilePictureUrl String?   @map("profile_picture_url") @db.VarChar(2048)
  waId              String?   @map("wa_id")
  /// Conversa WhatsApp em grupo (@g.us) — destino de envio usa waId (JID do grupo).
  isGroupChat       Boolean   @default(false) @map("is_group_chat")
  optedIn           Boolean   @default(false) @map("opted_in")
  optedInAt         DateTime? @map("opted_in_at")
  lifecycleStage    String?   @map("lifecycle_stage") @db.VarChar(64)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  accountId String?  @map("account_id") @db.Uuid
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)

  pipelineStageId String?        @map("pipeline_stage_id") @db.Uuid
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)

  tags                ContactTag[]
  conversations       Conversation[]
  reminders           Reminder[]
  dealsPrimary        Deal[]                       @relation("DealPrimaryContact")
  broadcastRecipients BroadcastCampaignRecipient[]
  wavoipCallLogs      WavoipCallLog[]
  threeCxCallLogs     ThreeCxCallLog[]
  nvoipCallLogs          NvoipCallLog[]
  nvoipTorpedoDispatches NvoipTorpedoDispatch[]
  nvoipOtpChallenges     NvoipOtpChallenge[]

  @@unique([organizationId, phone])
  @@index([organizationId])
