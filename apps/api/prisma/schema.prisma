generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  TEMPLATE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum BroadcastCampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TimelineSubjectType {
  CONTACT
  ACCOUNT
  DEAL
}

enum TeamMemberRole {
  TEAM_ADMIN
  SUPERVISOR
  MEMBER
}

/// Como o valor à finalização (closure) entra nas somas e como negócios herdam o estado por etapa.
enum LeadValueRollup {
  /// Conta em «Em negociação» / pipeline; negócio fica OPEN.
  PIPELINE
  /// Conta em «Soma dos valores» (vendido); negócio WON.
  WON
  /// Negócio LOST; valor não entra nas somas principais.
  LOST
  /// Suporte etc.: valor e negócio não entram nas somas comerciais.
  NONE
}

enum BotType {
  WEBHOOK
  DIALOGFLOW
  CUSTOM
}

/// Níveis de log de execução de automação (estilo n8n / pipelines).
enum AutomationLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  /// Plano comercial (free | growth | enterprise) — quotas e faturação são informativas até integração de pagamentos.
  planTier            String  @default("free") @map("plan_tier") @db.VarChar(32)
  billingEmail        String? @map("billing_email") @db.VarChar(255)
  /// Limite mensal opcional de mensagens enviadas+recebidas (null = ilimitado na app).
  monthlyMessageQuota Int?    @map("monthly_message_quota")

  users              User[]
  contacts           Contact[]
  conversations      Conversation[]
  tags               Tag[]
  pipelines          Pipeline[]
  accounts           Account[]
  products           Product[]
  deals              Deal[]
  timelineEvents     TimelineEvent[]
  leadTypes          LeadType[]
  reminders          Reminder[]
  messageTemplates   MessageTemplate[]
  autoTagRules       AutoTagRule[]
  settings           Settings?
  auditLogs          AuditLog[]
  featureFlags       OrganizationFeatureFlag[]
  teams              Team[]
  bots               Bot[]
  broadcastCampaigns BroadcastCampaign[]
  inboxes            Inbox[]

  automationKnowledgeArticles    AutomationKnowledgeArticle[]
  automationKnowledgeSources     AutomationKnowledgeSource[]
  automationKnowledgeChunks      AutomationKnowledgeChunk[]
  kbSearchCaches                 KbSearchCache[]
  kbSearchLogs                   KbSearchLog[]
  automationPromptModules        AutomationPromptModule[]
  automationAgentProfiles        AutomationAgentProfile[]
  automationCustomTools          AutomationCustomTool[]
  automationInteractions         AutomationInteraction[]
  automationConversationContexts AutomationConversationContext[]
  automationToolExecutions       AutomationToolExecution[]
  automationExecutions           AutomationExecution[]
  automationExecutionLogSettings AutomationExecutionLogSettings?

  @@map("organizations")
}

/// Canais de caixa de entrada no estilo [Chatwoot](https://www.chatwoot.com/docs/user-guide/add-inbox-settings).
/// Nem todos têm integração real na app; o valor persiste para organização e evolução futura.
enum InboxChannelType {
  WEBSITE
  FACEBOOK
  WHATSAPP
  SMS
  EMAIL
  API
  TELEGRAM
  LINE
  INSTAGRAM
  VOICE
}

model Inbox {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  description   String?          @db.Text
  channelType   InboxChannelType @default(WHATSAPP) @map("channel_type")
  /// Token secreto (URL) para webhooks e widget. Só mostrar a administradores.
  ingestToken   String?          @unique @map("ingest_token") @db.VarChar(64)
  channelConfig Json?            @map("channel_config")
  isDefault     Boolean          @default(false) @map("is_default")
  /// Bot de triagem (primeira linha) só para esta caixa; se vazio, usa `Settings.agentBotId` da organização.
  agentBotId    String?          @map("agent_bot_id") @db.Uuid
  agentBot      Bot?             @relation("InboxAgentBot", fields: [agentBotId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members       InboxMember[]
  conversations Conversation[]

  @@index([organizationId])
  @@index([agentBotId])
  @@map("inboxes")
}

model InboxMember {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  inboxId String @map("inbox_id") @db.Uuid
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inboxId, userId])
  @@index([userId])
  @@map("inbox_members")
}

model Team {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String
  description          String?  @db.Text
  avatarUrl            String?  @map("avatar_url") @db.VarChar(2048)
  businessHours        Json?    @map("business_hours")
  notificationSettings Json?    @map("notification_settings")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members       TeamMember[]
  conversations Conversation[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(uuid()) @db.Uuid
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")

  teamId String @map("team_id") @db.Uuid
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Bot {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  avatarUrl   String?  @map("avatar_url") @db.VarChar(2048)
  type        BotType  @default(WEBHOOK)
  webhookUrl  String?  @map("webhook_url") @db.VarChar(2048)
  config      Json?
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inboxTokenPrefix String? @map("inbox_token_prefix") @db.VarChar(16)
  inboxTokenHash   String? @map("inbox_token_hash") @db.Text
  /// Segredo opcional: assinatura HMAC-SHA256 (cabeçalho X-OpenConduit-Signature) nos POST enviados ao webhookUrl.
  webhookSecret    String? @map("webhook_secret") @db.VarChar(512)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  interactions    BotInteraction[]
  settingsAsAgent Settings?        @relation("SettingsAgentBot")
  inboxesAsAgent  Inbox[]          @relation("InboxAgentBot")

  automationProfile              AutomationAgentProfile?
  automationCustomTools          AutomationCustomTool[]
  automationInteractions         AutomationInteraction[]
  automationConversationContexts AutomationConversationContext[]
  automationKnowledgeArticleBots AutomationKnowledgeArticleBot[]
  automationExecutions           AutomationExecution[]

  @@unique([inboxTokenPrefix])
  @@index([organizationId])
  @@map("bots")
}

model BotInteraction {
  id        String   @id @default(uuid()) @db.Uuid
  direction String   @db.VarChar(32)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  botId String @map("bot_id") @db.Uuid
  bot   Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  conversationId String?       @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([botId, createdAt])
  @@index([conversationId])
  @@map("bot_interactions")
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String
  displayName              String?   @map("display_name") @db.VarChar(200)
  email                    String    @unique
  passwordHash             String    @map("password_hash")
  messageSignature         String?   @map("message_signature") @db.Text
  /// Na UI da conversa, mostrar o nome do atendente em cada mensagem enviada (equipa).
  showAgentNameInChat      Boolean   @default(false) @map("show_agent_name_in_chat")
  /// Token de API pessoal (estilo Chatwoot) para integrações por utilizador.
  apiAccessTokenPrefix     String?   @map("api_access_token_prefix") @db.VarChar(16)
  apiAccessTokenHash       String?   @map("api_access_token_hash") @db.Text
  apiAccessTokenLastUsedAt DateTime? @map("api_access_token_last_used_at")
  role                     UserRole  @default(AGENT)
  createdAt                DateTime  @default(now()) @map("created_at")

  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assignedContacts             Contact[]                     @relation("AssignedContacts")
  createdContacts              Contact[]                     @relation("ContactCreator")
  assignedConversations        Conversation[]                @relation("AssignedConversations")
  reminders                    Reminder[]
  auditLogs                    AuditLog[]
  platformAppsCreated          PlatformApplication[]
  ownedAccounts                Account[]                     @relation("AccountOwner")
  ownedDeals                   Deal[]                        @relation("DealOwner")
  timelineEvents               TimelineEvent[]
  teamMemberships              TeamMember[]
  inboxMemberships             InboxMember[]
  messagesAsActor              Message[]                     @relation("MessageActor")
  broadcastCampaignsCreated    BroadcastCampaign[]           @relation("BroadcastCampaignCreator")
  automationKnowledgeRevisions AutomationKnowledgeRevision[]
  conversationReadStates       ConversationUserReadState[]

  @@index([organizationId])
  @@map("users")
}

/// Última vez que o utilizador abriu a conversa no painel — para ocultar badge de transferência de equipa.
model ConversationUserReadState {
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([userId])
  @@map("conversation_user_read_states")
}

model Contact {
  id                String    @id @default(uuid()) @db.Uuid
  phone             String
  name              String
  email             String?
  notes             String?   @db.Text
  /// URL da foto de perfil WhatsApp (Evolution API / webhooks CONTACTS_*).
  profilePictureUrl String?   @map("profile_picture_url") @db.VarChar(2048)
  waId              String?   @map("wa_id")
  /// Conversa WhatsApp em grupo (@g.us) — destino de envio usa waId (JID do grupo).
  isGroupChat       Boolean   @default(false) @map("is_group_chat")
  optedIn           Boolean   @default(false) @map("opted_in")
  optedInAt         DateTime? @map("opted_in_at")
  lifecycleStage    String?   @map("lifecycle_stage") @db.VarChar(64)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  accountId String?  @map("account_id") @db.Uuid
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)

  pipelineStageId String?        @map("pipeline_stage_id") @db.Uuid
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)

  tags                ContactTag[]
  conversations       Conversation[]
  reminders           Reminder[]
  dealsPrimary        Deal[]                       @relation("DealPrimaryContact")
  broadcastRecipients BroadcastCampaignRecipient[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([pipelineStageId])
  @@index([accountId])
  @@map("contacts")
}

model Tag {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  color          String       @db.VarChar(7)
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contacts               ContactTag[]
  rules                  AutoTagRule[]
  broadcastCampaignTags  BroadcastCampaignTag[]
  settingsAutoResolveTag Settings[]             @relation("SettingsAutoResolveTag")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model ContactTag {
  contactId String @map("contact_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stages PipelineStage[]
  deals  Deal[]

  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id             String @id @default(uuid()) @db.Uuid
  name           String
  order          Int
  color          String @db.VarChar(7)
  probabilityPct Int    @default(0) @map("probability_pct")

  pipelineId String   @map("pipeline_id") @db.Uuid
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  /// When set, this stage is the CRM kanban column for that lead type (same as "Tipos de lead").
  leadTypeId String?   @map("lead_type_id") @db.Uuid
  leadType   LeadType? @relation(fields: [leadTypeId], references: [id], onDelete: SetNull)

  contacts Contact[]
  deals    Deal[]

  @@unique([pipelineId, name])
  @@index([pipelineId])
  @@index([leadTypeId])
  @@map("pipeline_stages")
}

model Account {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  website   String?
  industry  String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId String? @map("owner_id") @db.Uuid
  owner   User?   @relation("AccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts Contact[]
  deals    Deal[]

  @@index([organizationId])
  @@map("accounts")
}

model Product {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  sku        String?
  priceCents Int      @default(0) @map("price_cents")
  currency   String   @default("BRL") @db.VarChar(3)
  isActive   Boolean  @default(true) @map("is_active")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  lineItems DealLineItem[]

  @@index([organizationId])
  @@map("products")
}

model Deal {
  id             String     @id @default(uuid()) @db.Uuid
  name           String
  status         DealStatus @default(OPEN)
  amountCents    Int        @default(0) @map("amount_cents")
  currency       String     @default("BRL") @db.VarChar(3)
  probabilityPct Int?       @map("probability_pct")
  closeDate      DateTime?  @map("close_date")
  lostReason     String?    @map("lost_reason") @db.Text
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  pipelineId String   @map("pipeline_id") @db.Uuid
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Restrict)

  stageId String        @map("stage_id") @db.Uuid
  stage   PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  accountId String?  @map("account_id") @db.Uuid
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  primaryContactId String?  @map("primary_contact_id") @db.Uuid
  primaryContact   Contact? @relation("DealPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  ownerId String? @map("owner_id") @db.Uuid
  owner   User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  lineItems DealLineItem[]

  @@index([organizationId])
  @@index([pipelineId])
  @@index([stageId])
  @@map("deals")
}

model DealLineItem {
  id             String @id @default(uuid()) @db.Uuid
  description    String @db.Text
  quantity       Int    @default(1)
  unitPriceCents Int    @default(0) @map("unit_price_cents")
  discountPct    Int    @default(0) @map("discount_pct")

  dealId String @map("deal_id") @db.Uuid
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  productId String?  @map("product_id") @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@map("deal_line_items")
}

model TimelineEvent {
  id          String              @id @default(uuid()) @db.Uuid
  subjectType TimelineSubjectType @map("subject_type")
  subjectId   String              @map("subject_id") @db.Uuid
  eventType   String              @map("event_type") @db.VarChar(120)
  channel     String?             @db.VarChar(32)
  payload     Json
  sourceId    String?             @map("source_id") @db.VarChar(120)
  occurredAt  DateTime            @default(now()) @map("occurred_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, subjectType, subjectId, occurredAt])
  @@map("timeline_events")
}

model LeadType {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  color          String          @db.VarChar(7)
  order          Int             @default(0) @map("sort_order")
  /// Soma em auditoria / Meu atendimento e estado do negócio quando a etapa do funil corresponde a este tipo.
  valueRollup    LeadValueRollup @default(PIPELINE) @map("value_roll_up")
  organizationId String          @map("organization_id") @db.Uuid
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversations               Conversation[]
  pipelineStages              PipelineStage[]
  settingsAutoResolveLeadType Settings[]      @relation("SettingsAutoResolveLeadType")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("lead_types")
}

model Conversation {
  id        String             @id @default(uuid()) @db.Uuid
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inboxId String @map("inbox_id") @db.Uuid
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Restrict)

  contactId String  @map("contact_id") @db.Uuid
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)

  leadTypeId      String?   @map("lead_type_id") @db.Uuid
  leadType        LeadType? @relation(fields: [leadTypeId], references: [id], onDelete: SetNull)
  closureReason   String?   @map("closure_reason") @db.Text
  /// Valor opcional associado ao lead quando a conversa é finalizada (acompanhamento comercial).
  closureValue    Float?    @map("closure_value")
  /// CSAT 1–5: preenchido pelo cliente via link (inquérito pós-resolução).
  csatScore       Int?      @map("csat_score")
  csatComment     String?   @map("csat_comment") @db.Text
  csatRecordedAt  DateTime? @map("csat_recorded_at")
  /// Token opaco para o link público de avaliação (limpo ao reabrir ou após submissão).
  csatSurveyToken String?   @unique @map("csat_survey_token") @db.VarChar(48)

  teamId String? @map("team_id") @db.Uuid
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  /// Marca temporal quando a conversa entra numa equipa por transferência — usada para badge «não vista» por utilizador.
  teamTransferPulseAt DateTime? @map("team_transfer_pulse_at")

  /// Após transferência pelo agente nativo: não voltar a responder até voltar a `PENDING` (fila do bot) ou `awaitingHumanHandoff` limpo.
  awaitingHumanHandoff Boolean @default(false) @map("awaiting_human_handoff")

  messages               Message[]
  userReadStates         ConversationUserReadState[]
  botInteractions        BotInteraction[]
  automationContext      AutomationConversationContext?
  automationInteractions AutomationInteraction[]
  automationExecutions   AutomationExecution[]

  @@index([organizationId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@index([leadTypeId])
  @@index([teamId])
  @@index([inboxId])
  @@map("conversations")
}

model Message {
  id            String           @id @default(uuid()) @db.Uuid
  direction     MessageDirection
  type          MessageType      @default(TEXT)
  body          String?          @db.Text
  mediaUrl      String?          @map("media_url")
  mediaType     String?          @map("media_type")
  /// Nota interna da equipa: não é enviada ao WhatsApp.
  isPrivate     Boolean          @default(false) @map("is_private")
  providerMsgId String?          @map("provider_msg_id")
  status        MessageStatus    @default(SENT)
  sentAt        DateTime         @default(now()) @map("sent_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation("MessageActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([providerMsgId])
  @@index([actorUserId])
  @@map("messages")
}

model Reminder {
  id        String   @id @default(uuid()) @db.Uuid
  note      String   @db.Text
