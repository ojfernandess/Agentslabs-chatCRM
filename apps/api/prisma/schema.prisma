  direction      String    @db.VarChar(16)
  caller         String    @db.VarChar(32)
  receiver       String    @db.VarChar(32)
  status         String    @db.VarChar(64)
  durationSec    Int?      @map("duration_sec")
  recordUrl      String?   @map("record_url") @db.VarChar(2048)
  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  rawPayload     Json?     @map("raw_payload")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nvoipAccountId String       @map("nvoip_account_id") @db.Uuid
  nvoipAccount   NvoipAccount @relation(fields: [nvoipAccountId], references: [id], onDelete: Cascade)

  contactId String?  @map("contact_id") @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  conversationId String?       @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  messageId String?  @unique @map("message_id") @db.Uuid
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  initiatedByUserId String? @map("initiated_by_user_id") @db.Uuid
  initiatedByUser   User?   @relation("NvoipCallInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  clientCallId      String? @unique @map("client_call_id") @db.VarChar(128)

  @@unique([nvoipAccountId, externalCallId])
  @@index([organizationId])
  @@index([nvoipAccountId])
  @@index([initiatedByUserId])
  @@map("nvoip_call_logs")
}

model NvoipIntegrationLog {
  id        String   @id @default(uuid()) @db.Uuid
  level     String   @db.VarChar(16)
  eventType String   @map("event_type") @db.VarChar(64)
  message   String   @db.Text
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nvoipAccountId String?       @map("nvoip_account_id") @db.Uuid
  nvoipAccount   NvoipAccount? @relation(fields: [nvoipAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("nvoip_integration_logs")
}

model NvoipTorpedoDispatch {
  id             String   @id @default(uuid()) @db.Uuid
  calledPhone    String   @map("called_phone") @db.VarChar(32)
  caller         String   @db.VarChar(32)
  messageText    String   @map("message_text") @db.Text
  webhookToken   String   @unique @map("webhook_token") @db.VarChar(64)
  externalCallId String?  @map("external_call_id") @db.VarChar(128)
  schedkey       String?  @db.VarChar(128)
  status         String   @default("SENT") @db.VarChar(32)
  dtmfRules      Json?    @map("dtmf_rules")
  dtmfPressed    Json?    @map("dtmf_pressed")
  rawPayload     Json?    @map("raw_payload")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nvoipAccountId String       @map("nvoip_account_id") @db.Uuid
  nvoipAccount   NvoipAccount @relation(fields: [nvoipAccountId], references: [id], onDelete: Cascade)

  campaignId String?            @map("campaign_id") @db.Uuid
  campaign   BroadcastCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  contactId String?  @map("contact_id") @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([campaignId])
  @@index([contactId])
  @@map("nvoip_torpedo_dispatches")
}

model NvoipScheduledTorpedo {
  id              String    @id @default(uuid()) @db.Uuid
  schedkey        String    @unique @db.VarChar(128)
  status          String    @default("SCHEDULED") @db.VarChar(32)
  recipientCount  Int       @default(0) @map("recipient_count")
  payload         Json?
  scheduledAt     DateTime? @map("scheduled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nvoipAccountId String       @map("nvoip_account_id") @db.Uuid
  nvoipAccount   NvoipAccount @relation(fields: [nvoipAccountId], references: [id], onDelete: Cascade)

  campaignId String?            @map("campaign_id") @db.Uuid
  campaign   BroadcastCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("nvoip_scheduled_torpedos")
}
