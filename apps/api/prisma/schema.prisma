  alertEmail      String?            @map("alert_email") @db.VarChar(255)
  alertMinLevel   AutomationLogLevel @default(ERROR) @map("alert_min_level")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("automation_execution_log_settings")
}
