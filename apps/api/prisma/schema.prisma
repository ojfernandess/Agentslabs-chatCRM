/// Segmentos de texto com embeddings para busca semântica (RAG) sobre artigos da KB.
model AutomationKnowledgeChunk {
  id              String                      @id @default(uuid()) @db.Uuid
  organizationId  String                      @map("organization_id") @db.Uuid
  organization    Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  articleId       String                      @map("article_id") @db.Uuid
  article         AutomationKnowledgeArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  chunkIndex      Int                         @map("chunk_index")
  text            String                      @db.Text
  embeddingModel  String                      @default("text-embedding-3-small") @map("embedding_model") @db.VarChar(80)
  dimensions      Int                         @default(1536)
  /// pgvector — usar `$executeRaw` / `$queryRaw` (Prisma não serializa `vector` no client).
  embeddingVector Unsupported("vector(1536)") @map("embedding_vector")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@unique([articleId, chunkIndex])
  @@index([organizationId])
  @@index([articleId])
  @@map("automation_knowledge_chunks")
}

