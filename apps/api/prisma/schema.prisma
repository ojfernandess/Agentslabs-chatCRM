model BroadcastCampaign {
  id          String                  @id @default(uuid()) @db.Uuid
  name        String                  @db.VarChar(200)
  status      BroadcastCampaignStatus @default(DRAFT)
  channel     BroadcastChannel        @default(WHATSAPP)
  /// Apenas TEXT ou TEMPLATE são aceites na API de campanhas (WhatsApp).
  messageType MessageType             @map("message_type")
  body        String?                 @db.Text
  templateId  String?                 @map("template_id") @db.Uuid
  subject     String?                 @db.VarChar(500)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inboxId String? @map("inbox_id") @db.Uuid
  inbox   Inbox?  @relation(fields: [inboxId], references: [id], onDelete: SetNull)

  createdById String @map("created_by_id") @db.Uuid
  createdBy   User   @relation("BroadcastCampaignCreator", fields: [createdById], references: [id], onDelete: Restrict)

  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  scheduleType   BroadcastScheduleType   @default(IMMEDIATE) @map("schedule_type")
  scheduledAt    DateTime?               @map("scheduled_at")
  cronExpression String?                 @map("cron_expression") @db.VarChar(120)
  nextRunAt      DateTime?               @map("next_run_at")
  eventTrigger   String?                 @map("event_trigger") @db.VarChar(64)
  eventConfig    Json?                   @map("event_config")
  segmentRules   Json?                   @map("segment_rules")
  flowDefinition Json?                   @map("flow_definition")
  abConfig       Json?                   @map("ab_config")

  requiresApproval Boolean                 @default(false) @map("requires_approval")
  approvalStatus   BroadcastApprovalStatus @default(NONE) @map("approval_status")
  approvedById     String?                 @map("approved_by_id") @db.Uuid
  approvedBy       User?                   @relation("BroadcastCampaignApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?               @map("approved_at")
  rejectionReason  String?                 @map("rejection_reason") @db.Text

  integrationToolId String?               @map("integration_tool_id") @db.Uuid
  integrationTool   AutomationCustomTool? @relation(fields: [integrationToolId], references: [id], onDelete: SetNull)

  throttleMs          Int      @default(750) @map("throttle_ms")
  useDistributedQueue Boolean  @default(true) @map("use_distributed_queue")
  revenuePerConversion Decimal? @map("revenue_per_conversion") @db.Decimal(12, 2)

  pausedAt        DateTime? @map("paused_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  totalRecipients Int       @default(0) @map("total_recipients")
  sentCount       Int       @default(0) @map("sent_count")
  failedCount     Int       @default(0) @map("failed_count")
  responseCount   Int       @default(0) @map("response_count")
  conversionCount Int       @default(0) @map("conversion_count")
  roiValue        Decimal?  @map("roi_value") @db.Decimal(14, 2)
  lastError       String?   @map("last_error") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
