model Settings {
  id                        String       @id @default(uuid()) @db.Uuid
  organizationId            String       @unique @map("organization_id") @db.Uuid
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappProvider          String?      @map("whatsapp_provider")
  whatsappApiKey            String?      @map("whatsapp_api_key")
  whatsappPhoneNumberId     String?      @map("whatsapp_phone_number_id")
  evolutionApiBaseUrl       String?      @map("evolution_api_base_url") @db.VarChar(512)
  whatsappWebhookSecret     String?      @map("whatsapp_webhook_secret")
  /// Token hub.verify_token para verificação GET do webhook Meta Cloud API.
  whatsappWebhookVerifyToken String?     @map("whatsapp_webhook_verify_token") @db.VarChar(128)
  autoOptInOnFirstMessage   Boolean      @default(false) @map("auto_opt_in_on_first_message")
  notifyConversationOpen    Boolean      @default(true) @map("notify_conversation_open")
  notifyConversationPending Boolean      @default(true) @map("notify_conversation_pending")
  /// Uma única thread por contacto no canal (reabre a última conversa ao receber mensagem).
  lockSingleConversation    Boolean      @default(false) @map("lock_single_conversation")

  /// Agent bot: novas conversas WhatsApp podem entrar em PENDING e receber webhook `message_created`.
  agentBotId String? @unique @map("agent_bot_id") @db.Uuid
  agentBot   Bot?    @relation("SettingsAgentBot", fields: [agentBotId], references: [id], onDelete: SetNull)

  /// Inquérito CSAT: ao resolver, envia ao contacto um link para avaliar (1–5).
  csatEnabled       Boolean @default(false) @map("csat_enabled")
  csatSurveyMessage String? @map("csat_survey_message") @db.Text
  /// Formato da avaliação na página pública: number | star | emoji.
  csatRatingType    String  @default("number") @map("csat_rating_type") @db.VarChar(16)

  /// Resolução automática por inatividade (regras ao estilo «fluxos de conversa»).
  autoResolveConversationsEnabled Boolean   @default(false) @map("auto_resolve_conversations_enabled")
  /// Duração mínima de inatividade antes de resolver (em minutos; 1–43200).
  autoResolveInactivityMinutes    Int       @default(10) @map("auto_resolve_inactivity_minutes")
  /// Mensagem opcional ao cliente após a resolução automática (WhatsApp).
  autoResolveCustomerMessage      String?   @map("auto_resolve_customer_message") @db.Text
  /// Se verdadeiro, não resolver conversas com agente atribuído (aguardam resposta humana).
  autoResolveSkipWhenAssigned     Boolean   @default(false) @map("auto_resolve_skip_when_assigned")
  autoResolveTagId                String?   @map("auto_resolve_tag_id") @db.Uuid
  autoResolveLeadTypeId           String?   @map("auto_resolve_lead_type_id") @db.Uuid
  autoResolveTag                  Tag?      @relation("SettingsAutoResolveTag", fields: [autoResolveTagId], references: [id], onDelete: SetNull)
  autoResolveLeadType             LeadType? @relation("SettingsAutoResolveLeadType", fields: [autoResolveLeadTypeId], references: [id], onDelete: SetNull)

  /// Finalização manual: exigir motivo (mín. 3 caracteres) ao resolver.
  resolveRequireClosureReason Boolean @default(true) @map("resolve_require_closure_reason")
  /// Finalização manual: exigir tipo de lead ao resolver.
  resolveRequireLeadType      Boolean @default(true) @map("resolve_require_lead_type")
  /// Finalização manual: mostrar opção de agendar lembrete para o contacto.
  resolveOfferReminder        Boolean @default(true) @map("resolve_offer_reminder")

  /// Transcrever mensagens de áudio recebidas (WhatsApp / caixas) para texto — requer chave OpenAI no servidor.
  audioTranscriptionEnabled Boolean @default(false) @map("audio_transcription_enabled")
  /// Transcrever imagens recebidas (descrição + OCR) — requer chave OpenAI no servidor.
  imageTranscriptionEnabled Boolean @default(false) @map("image_transcription_enabled")

  /// Chave OpenAI opcional da organização para «Gerar resposta» e IA & Insights (painel humano). Se null, usa a chave do servidor.
  assistantOpenaiApiKey      String? @map("assistant_openai_api_key") @db.Text
  /// Chave SerpApi (Google Maps) para prospecção Lead Finder.
  leadFinderSerpApiKey       String? @map("lead_finder_serp_api_key") @db.Text
  /// Base URL API compatível com OpenAI (ex. Azure). Se null, usa `OPENAI_API_BASE_URL` do servidor.
  assistantOpenaiApiBaseUrl String? @map("assistant_openai_api_base_url") @db.VarChar(512)

  /// Ativar/desativar IA & Insights e sugestão de resposta (painel humano).
  assistantAiEnabled Boolean @default(true) @map("assistant_ai_enabled")
  /// Permitir acesso (piloto) à Base de conhecimento IA e ferramentas.
  aiPilotAccessEnabled Boolean @default(false) @map("ai_pilot_access_enabled")

  /// Ao passar a conversa para a fila do bot (PENDING), não voltar a disparar o webhook com a última mensagem do cliente.
  silentTransferToAgentBot Boolean @default(false) @map("silent_transfer_to_agent_bot")

  /// Mostrar aba «Atendimento» em Conversas (OPEN sem atendente humano).
  conversationsAttendanceTabEnabled Boolean @default(false) @map("conversations_attendance_tab_enabled")
  /// Ao entrar em Conversas, abrir a aba Atendimento se houver conversas na fila.
  conversationsAttendanceTabAutoOpen Boolean @default(true) @map("conversations_attendance_tab_auto_open")
  /// Mostrar etiquetas do contacto nos cartões da lista de conversas.
  conversationsListShowContactTags Boolean @default(false) @map("conversations_list_show_contact_tags")
  /// Modo «Telefone rápido» em Nova mensagem (Conversas) para adicionar/seleccionar contacto por número.
  conversationsQuickContactAddEnabled Boolean @default(false) @map("conversations_quick_contact_add_enabled")

  /// URL para webhook de alertas de IA (sentimento negativo, frustração, etc.).
  aiAlertWebhookUrl String? @map("ai_alert_webhook_url") @db.VarChar(2048)
  /// Segredo opcional para assinatura HMAC-SHA256 do webhook de alertas de IA.
  aiAlertWebhookSecret String? @map("ai_alert_webhook_secret") @db.Text

  /// Cores dos balões de conversa (cliente / atendente) — modo claro e escuro (#RRGGBB).
  conversationBubbleClientColor     String? @map("conversation_bubble_client_color") @db.VarChar(7)
  conversationBubbleAgentColor      String? @map("conversation_bubble_agent_color") @db.VarChar(7)
  conversationBubbleClientColorDark String? @map("conversation_bubble_client_color_dark") @db.VarChar(7)
  conversationBubbleAgentColorDark  String? @map("conversation_bubble_agent_color_dark") @db.VarChar(7)
  conversationBubbleClientTextColor     String? @map("conversation_bubble_client_text_color") @db.VarChar(7)
  conversationBubbleAgentTextColor      String? @map("conversation_bubble_agent_text_color") @db.VarChar(7)
  conversationBubbleClientTextColorDark String? @map("conversation_bubble_client_text_color_dark") @db.VarChar(7)
  conversationBubbleAgentTextColorDark  String? @map("conversation_bubble_agent_text_color_dark") @db.VarChar(7)
  conversationBubbleAgentNameColor      String? @map("conversation_bubble_agent_name_color") @db.VarChar(7)
  conversationBubbleAgentNameColorDark  String? @map("conversation_bubble_agent_name_color_dark") @db.VarChar(7)
  conversationBubbleClientMetaColor     String? @map("conversation_bubble_client_meta_color") @db.VarChar(7)
  conversationBubbleClientMetaColorDark String? @map("conversation_bubble_client_meta_color_dark") @db.VarChar(7)
  conversationBubbleAgentMetaColor      String? @map("conversation_bubble_agent_meta_color") @db.VarChar(7)
  conversationBubbleAgentMetaColorDark  String? @map("conversation_bubble_agent_meta_color_dark") @db.VarChar(7)

  /// Logo opcional da organização (URL absoluta). Se null, a UI usa a logo do sistema.
  organizationLogoUrl String? @map("organization_logo_url") @db.VarChar(2048)

  @@map("settings")
}

