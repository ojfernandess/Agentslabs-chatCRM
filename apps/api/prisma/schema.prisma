model Conversation {
  id        String             @id @default(uuid()) @db.Uuid
  status    ConversationStatus @default(OPEN)
  priority  ConversationPriority? @map("priority")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  /// Soft-delete (lixeira de e-mail / conversas). Null = ativo.
  deletedAt DateTime?          @map("deleted_at")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inboxId String @map("inbox_id") @db.Uuid
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Restrict)

  contactId String  @map("contact_id") @db.Uuid
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)

  leadTypeId      String?   @map("lead_type_id") @db.Uuid
  leadType        LeadType? @relation(fields: [leadTypeId], references: [id], onDelete: SetNull)
  closureReason   String?   @map("closure_reason") @db.Text
  /// Valor opcional associado ao lead quando a conversa é finalizada (acompanhamento comercial).
  closureValue    Float?    @map("closure_value")
  /// CSAT 1–5: preenchido pelo cliente via link (inquérito pós-resolução).
  csatScore       Int?      @map("csat_score")
  csatComment     String?   @map("csat_comment") @db.Text
  csatRecordedAt  DateTime? @map("csat_recorded_at")
  /// Token opaco para o link público de avaliação (limpo ao reabrir ou após submissão).
  csatSurveyToken String?   @unique @map("csat_survey_token") @db.VarChar(48)

  teamId String? @map("team_id") @db.Uuid
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  /// Marca temporal quando a conversa entra numa equipa por transferência — usada para badge «não vista» por utilizador.
  teamTransferPulseAt DateTime? @map("team_transfer_pulse_at")

  /// Após transferência pelo agente nativo: não voltar a responder até voltar a `PENDING` (fila do bot) ou `awaitingHumanHandoff` limpo.
  awaitingHumanHandoff Boolean @default(false) @map("awaiting_human_handoff")

  messages               Message[]
  closureRecords         ConversationClosureRecord[]
  userReadStates         ConversationUserReadState[]
  userEmailStates        ConversationUserEmailState[]
  botInteractions        BotInteraction[]
  automationContext      AutomationConversationContext?
  automationInteractions AutomationInteraction[]
  automationExecutions   AutomationExecution[]
  chatbotFlowSession     ChatbotFlowSession?
  wavoipCallLogs         WavoipCallLog[]
  threeCxCallLogs        ThreeCxCallLog[]
  nvoipCallLogs          NvoipCallLog[]
  reminders              Reminder[]

  @@index([organizationId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@index([leadTypeId])
  @@index([teamId])
  @@index([inboxId])
  @@index([deletedAt])
  @@map("conversations")
}

/// Registo permanente de cada encerramento (auditoria); reabertura não apaga o histórico.
model ConversationClosureRecord {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  sessionIndex   Int      @map("session_index")
  resolvedAt     DateTime @map("resolved_at")
  resolvedById   String   @map("resolved_by_id") @db.Uuid
  assignedToId   String?  @map("assigned_to_id") @db.Uuid
  teamId         String?  @map("team_id") @db.Uuid
  leadTypeId     String?  @map("lead_type_id") @db.Uuid
  closureReason  String?  @map("closure_reason") @db.Text
  closureValue   Float?   @map("closure_value")
  csatScore      Int?     @map("csat_score")
  csatComment    String?  @map("csat_comment") @db.Text
  csatRecordedAt DateTime? @map("csat_recorded_at")
  reopenedAt     DateTime? @map("reopened_at")
  reopenedById   String?  @map("reopened_by_id") @db.Uuid
  /// Verdadeiro quando outro atendente reabriu ou encerrou após reabertura por terceiro.
  isNewAttendance Boolean @default(false) @map("is_new_attendance")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  resolvedBy   User         @relation("ClosureRecordResolvedBy", fields: [resolvedById], references: [id], onDelete: Restrict)
  reopenedBy   User?        @relation("ClosureRecordReopenedBy", fields: [reopenedById], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("ClosureRecordAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  leadType     LeadType?    @relation(fields: [leadTypeId], references: [id], onDelete: SetNull)
  reminders    Reminder[]

  @@unique([conversationId, sessionIndex])
  @@index([organizationId, resolvedAt])
  @@index([conversationId])
  @@index([assignedToId])
  @@index([leadTypeId])
  @@index([teamId])
  @@map("conversation_closure_records")
}

model Message {
  id            String           @id @default(uuid()) @db.Uuid
  direction     MessageDirection
  type          MessageType      @default(TEXT)
  body          String?          @db.Text
  mediaUrl      String?          @map("media_url")
  mediaType     String?          @map("media_type")
  /// Nota interna da equipa: não é enviada ao WhatsApp.
  isPrivate     Boolean          @default(false) @map("is_private")
  providerMsgId String?          @map("provider_msg_id")
  status        MessageStatus    @default(SENT)
  sentAt        DateTime         @default(now()) @map("sent_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation("MessageActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  wavoipCallLog WavoipCallLog?
  threeCxCallLog ThreeCxCallLog?
  nvoipCallLog   NvoipCallLog?

  @@index([conversationId])
  @@index([providerMsgId])
  @@index([actorUserId])
  @@map("messages")
}

model Reminder {
  id        String   @id @default(uuid()) @db.Uuid
  note      String   @db.Text
  dueAt     DateTime @map("due_at")
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  status   ReminderStatus   @default(TODO)
  priority ReminderPriority @default(MEDIUM)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String  @map("contact_id") @db.Uuid
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversationId String? @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  closureRecordId String? @map("closure_record_id") @db.Uuid
  closureRecord   ConversationClosureRecord? @relation(fields: [closureRecordId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([dueAt])
  @@index([conversationId])
  @@map("reminders")
}

enum ReminderStatus {
  TODO
  DOING
  DONE
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model MessageTemplate {
