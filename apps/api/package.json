{
  "name": "@openconduit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && node -e \"require('node:fs').cpSync('public','dist/public',{recursive:true})\"",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:resolve:evolution-applied": "prisma migrate resolve --applied 20260202120000_add_evolution_api_base_url",
    "db:migrate:resolve:evolution-rolled-back": "prisma migrate resolve --rolled-back 20260202120000_add_evolution_api_base_url",
    "db:migrate:resolve:inbox-ingest-rolled-back": "prisma migrate resolve --rolled-back 20260518140000_inbox_ingest",
    "db:seed": "tsx prisma/seed.ts",
    "db:list-users": "tsx prisma/list-users.ts",
    "db:reset-password": "tsx prisma/reset-password.ts",
    "db:verify-password": "tsx prisma/verify-password.ts",
    "db:studio": "prisma studio",
    "test": "node --import tsx --test src/lib/messagePayload.test.ts src/lib/agentConversationHistory.test.ts src/lib/agent-engine/agentEngine.test.ts src/lib/agentVoiceSettings.test.ts src/lib/automationHttpToolExecute.test.ts src/lib/knowledgeAppendix.test.ts src/lib/automationExecutionLog.test.ts src/lib/broadcastErrorClassifier.test.ts src/lib/broadcastAnalyticsQuery.test.ts src/lib/broadcastAnalytics.integration.test.ts src/lib/metaWebhookPayload.test.ts src/providers/meta.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.8",
    "@openconduit/shared": "*",
    "@prisma/client": "^6.4.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.30.0",
    "date-fns": "^3.0.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.0",
    "imapflow": "^1.4.6",
    "ioredis": "^5.4.2",
    "mailparser": "^3.9.14",
    "mammoth": "^1.12.0",
    "mem0ai": "^3.1.1",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "prisma": "^6.4.0",
    "qrcode": "^1.5.4",
    "resend": "^4.8.0",
    "tsx": "^4.19.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0"
  }
}
